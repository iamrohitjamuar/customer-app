# ====================================================================
# Spring Boot / Java / Maven & Gradle Core Filters
# ====================================================================
# Compiled class files
*.class

# Log files
*.log

# Blueprints and execution binaries
*.jar
*.war
*.nar
*.ear
*.crash

# Maven directory outputs
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle directory outputs
build/
.gradle/
/bin/
gradle-wrapper.jar

# ====================================================================
# ReactJS / NodeJS Core Filters
# ====================================================================
# Dependency directories
node_modules/
jspm_packages/

# Production build tracking
build/
dist/
out/

# TypeScript compilation cache
*.tsbuildinfo

# Debug logs generated by package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local lockfiles (Optional: commit these if you want strict lock versions)
.pnpm-debug.log*

# ====================================================================
# IDE & Operating System Configurations
# ====================================================================
# JetBrains IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse IDE
.metadata/
.classpath
.project
.settings/
*.launch

# Visual Studio Code
.vscode/

# MacOS specific system tracking files
.DS_Store
.AppleDouble
.LSOverride
Icon


# Windows specific system files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs.促
Desktop.ini

# ====================================================================
# Security & Environment Contexts (CRITICAL)
# ====================================================================
# Never commit credentials, private encryption tokens, or API secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Application configuration variable files containing secrets
application-dev.properties
application-prod.properties
application-dev.yml
application-prod.yml